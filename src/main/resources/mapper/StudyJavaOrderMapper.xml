<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.studyjava.mapper.StudyJavaOrderMapper">

    <resultMap id="BaseResultMap" type="com.studyjava.domain.dao.StudyJavaOrderDao">
            <id property="orderId" column="order_id" jdbcType="BIGINT"/>
            <result property="orderNo" column="order_no" jdbcType="VARCHAR"/>
            <result property="userId" column="user_id" jdbcType="BIGINT"/>
            <result property="totalPrice" column="total_price" jdbcType="INTEGER"/>
            <result property="payStatus" column="pay_status" jdbcType="TINYINT"/>
            <result property="payType" column="pay_type" jdbcType="TINYINT"/>
            <result property="payTime" column="pay_time" jdbcType="TIMESTAMP"/>
            <result property="orderStatus" column="order_status" jdbcType="TINYINT"/>
            <result property="extraInfo" column="extra_info" jdbcType="VARCHAR"/>
            <result property="userName" column="user_name" jdbcType="VARCHAR"/>
            <result property="userPhone" column="user_phone" jdbcType="VARCHAR"/>
            <result property="userAddress" column="user_address" jdbcType="VARCHAR"/>
            <result property="createBy" column="create_by" jdbcType="VARCHAR"/>
            <result property="createTime" column="create_time" jdbcType="TIMESTAMP"/>
            <result property="updateBy" column="update_by" jdbcType="VARCHAR"/>
            <result property="updateTime" column="update_time" jdbcType="TIMESTAMP"/>
            <result property="isDeleted" column="is_deleted" jdbcType="TINYINT"/>
            <result property="remark" column="remark" jdbcType="VARCHAR"/>
    </resultMap>

    <sql id="Base_Column_List">
        `order_id`,`order_no`,`user_id`,
        `total_price`,`pay_status`,`pay_type`,
        `pay_time`,`order_status`,`extra_info`,
        `user_name`,`user_phone`,`user_address`,
        `create_by`,`create_time`,`update_by`,`update_time`,`is_deleted`,`remark`
    </sql>
    <!-- 查询订单列表 -->
    <select id="getOrderList" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List" />
        FROM
        study_java_order
        <if test="studyJavaOrderDao != null">
            <where>
                <if test="studyJavaOrderDao.orderNo != null and studyJavaOrderDao.orderNo != ''">
                    order_no = #{studyJavaOrderDao.orderNo,jdbcType=VARCHAR}
                </if>
                <if test="studyJavaOrderDao.userId != null">
                    and user_id = #{studyJavaOrderDao.userId,jdbcType=BIGINT}
                </if>
                <if test="studyJavaOrderDao.payStatus != null">
                    and pay_status = #{studyJavaOrderDao.payStatus,jdbcType=TINYINT}
                </if>
                <if test="studyJavaOrderDao.orderStatus != null">
                    and order_status = #{studyJavaOrderDao.orderStatus,jdbcType=TINYINT}
                </if>
                <if test="studyJavaOrderDao.createTime != null">
                    and create_time = #{studyJavaOrderDao.createTime,jdbcType=TIMESTAMP}
                </if>
                <if test="studyJavaOrderDao.updateTime != null">
                    and update_time = #{studyJavaOrderDao.updateTime,jdbcType=TIMESTAMP}
                </if>
                <if test="studyJavaOrderDao.isDeleted != null">
                    and is_deleted = #{studyJavaOrderDao.isDeleted,jdbcType=TINYINT}
                </if>
            </where>
        </if>
    </select>
    <!-- 查询订单详情 -->
    <select id="getOrderInfo" parameterType="com.studyjava.domain.dao.StudyJavaOrderDao" resultMap="BaseResultMap">
        select
        <include refid="Base_Column_List" />
        from study_java_order
        <where>
            is_deleted = 0
            <if test="studyJavaOrderDao != null">
                <if test="studyJavaOrderDao.orderId != null">
                    and order_id = #{studyJavaOrderDao.orderId,jdbcType=BIGINT}
                </if>
                <if test="studyJavaOrderDao.orderNo != null">
                    and order_no = #{studyJavaOrderDao.orderNo,jdbcType=VARCHAR}
                </if>
                <if test="studyJavaOrderDao.userId != null">
                    and user_id = #{studyJavaOrderDao.userId,jdbcType=BIGINT}
                </if>
                <if test="studyJavaOrderDao.payStatus != null">
                    and pay_status = #{studyJavaOrderDao.payStatus,jdbcType=TINYINT}
                </if>

            </if>

        </where>
    </select>

    <!-- 支付时锁定订单行，串行化同一订单的并发支付请求 -->
    <select id="getOrderByIdForUpdate" resultMap="BaseResultMap">
        select
        <include refid="Base_Column_List" />
        from study_java_order
        where order_id = #{orderId,jdbcType=BIGINT}
          and is_deleted = 0
        for update
    </select>
    <!-- 删除订单 -->
    <update id="deleteOrder"  parameterType="com.studyjava.domain.dao.StudyJavaOrderDao" >
        update study_java_order
        set is_deleted = 1
        <where>
            <if test="studyJavaOrderDao != null">
                <if test="studyJavaOrderDao.orderId != null">
                    and order_id = #{studyJavaOrderDao.orderId,jdbcType=BIGINT}
                </if>
            </if>
        </where>
    </update>


    <!-- 新建订单 -->
    <insert id="insertOrder" keyColumn="order_id" keyProperty="studyJavaOrderDao.orderId" parameterType="com.studyjava.domain.dao.StudyJavaOrderDao" useGeneratedKeys="true">
        insert into study_java_order
        ( order_id,order_no,user_id
        ,total_price,pay_status,pay_type
        ,pay_time,order_status,extra_info
        ,user_name,user_phone,user_address
        ,create_by,create_time,update_by,update_time,is_deleted,remark
        )
        values (#{studyJavaOrderDao.orderId,jdbcType=BIGINT},#{studyJavaOrderDao.orderNo,jdbcType=VARCHAR},#{studyJavaOrderDao.userId,jdbcType=BIGINT}
        ,#{studyJavaOrderDao.totalPrice,jdbcType=INTEGER},#{studyJavaOrderDao.payStatus,jdbcType=TINYINT},#{studyJavaOrderDao.payType,jdbcType=TINYINT}
        ,#{studyJavaOrderDao.payTime,jdbcType=TIMESTAMP},#{studyJavaOrderDao.orderStatus,jdbcType=TINYINT},#{studyJavaOrderDao.extraInfo,jdbcType=VARCHAR}
        ,#{studyJavaOrderDao.userName,jdbcType=VARCHAR},#{studyJavaOrderDao.userPhone,jdbcType=VARCHAR},#{studyJavaOrderDao.userAddress,jdbcType=VARCHAR}
        ,#{studyJavaOrderDao.createBy,jdbcType=VARCHAR},#{studyJavaOrderDao.createTime,jdbcType=TIMESTAMP},#{studyJavaOrderDao.updateBy,jdbcType=VARCHAR},#{studyJavaOrderDao.updateTime,jdbcType=TIMESTAMP},#{studyJavaOrderDao.isDeleted,jdbcType=TINYINT},#{studyJavaOrderDao.remark,jdbcType=VARCHAR}
        )
    </insert>

    <!-- 更新订单 -->
    <update id="updateOrder" parameterType="com.studyjava.domain.dao.StudyJavaOrderDao">
        update study_java_order
        <set>
            <if test="studyJavaOrderDao != null">
                <if test="studyJavaOrderDao.orderNo != null">
                    order_no = #{studyJavaOrderDao.orderNo,jdbcType=VARCHAR},
                </if>
                <if test="studyJavaOrderDao.userId != null">
                    user_id = #{studyJavaOrderDao.userId,jdbcType=BIGINT},
                </if>
                <if test="studyJavaOrderDao.totalPrice != null">
                    total_price = #{studyJavaOrderDao.totalPrice,jdbcType=INTEGER},
                </if>
                <if test="studyJavaOrderDao.payStatus != null">
                    pay_status = #{studyJavaOrderDao.payStatus,jdbcType=TINYINT},
                </if>
                <if test="studyJavaOrderDao.payType != null">
                    pay_type = #{studyJavaOrderDao.payType,jdbcType=TINYINT},
                </if>
                <if test="studyJavaOrderDao.payTime != null">
                    pay_time = #{studyJavaOrderDao.payTime,jdbcType=TIMESTAMP},
                </if>
                <if test="studyJavaOrderDao.orderStatus != null">
                    order_status = #{studyJavaOrderDao.orderStatus,jdbcType=TINYINT},
                </if>
                <if test="studyJavaOrderDao.extraInfo != null">
                    extra_info = #{studyJavaOrderDao.extraInfo,jdbcType=VARCHAR},
                </if>
                <if test="studyJavaOrderDao.userName != null">
                    user_name = #{studyJavaOrderDao.userName,jdbcType=VARCHAR},
                </if>
                <if test="studyJavaOrderDao.userPhone != null">
                    user_phone = #{studyJavaOrderDao.userPhone,jdbcType=VARCHAR},
                </if>
                <if test="studyJavaOrderDao.userAddress != null">
                    user_address = #{studyJavaOrderDao.userAddress,jdbcType=VARCHAR},
                </if>
                <if test="studyJavaOrderDao.createBy != null">
                    create_by = #{studyJavaOrderDao.createBy,jdbcType=VARCHAR},
                </if>
                <if test="studyJavaOrderDao.createTime != null">
                    create_time = #{studyJavaOrderDao.createTime,jdbcType=TIMESTAMP},
                </if>
                <if test="studyJavaOrderDao.updateBy != null">
                    update_by = #{studyJavaOrderDao.updateBy,jdbcType=VARCHAR},
                </if>
                <if test="studyJavaOrderDao.updateTime != null">
                    update_time = #{studyJavaOrderDao.updateTime,jdbcType=TIMESTAMP},
                </if>
                <if test="studyJavaOrderDao.isDeleted != null">
                    is_deleted = #{studyJavaOrderDao.isDeleted,jdbcType=TINYINT},
                </if>
                <if test="studyJavaOrderDao.remark != null">
                    remark = #{studyJavaOrderDao.remark,jdbcType=VARCHAR},
                </if>
            </if>
        </set>
        <where>
            <if test="studyJavaOrderDao != null">
                <if test="studyJavaOrderDao.orderId != null">
                    and order_id = #{studyJavaOrderDao.orderId,jdbcType=BIGINT}
                </if>
            </if>
        </where>
        </update>

    <!-- 使用旧状态作为更新条件，防止并发请求覆盖彼此的状态变更 -->
    <update id="transitionOrder">
        update study_java_order
        <set>
            order_status = #{targetStatus,jdbcType=TINYINT},
            update_time = CURRENT_TIMESTAMP,
            <if test="payStatus != null">
                pay_status = #{payStatus,jdbcType=TINYINT},
            </if>
            <if test="payType != null">
                pay_type = #{payType,jdbcType=TINYINT},
            </if>
            <if test="payTime != null">
                pay_time = #{payTime,jdbcType=TIMESTAMP},
            </if>
        </set>
        where order_id = #{orderId,jdbcType=BIGINT}
          and order_status = #{expectedStatus,jdbcType=TINYINT}
          and is_deleted = 0
    </update>

    <!-- 每日统计 -->
    <select id="getDailyStats" resultType="java.util.Map">
        SELECT
            COUNT(*) as totalOrders,
            IFNULL(SUM(total_price), 0) as totalRevenue
        FROM
            study_java_order
        WHERE
            create_time BETWEEN #{startTime} AND #{endTime}
            AND is_deleted = 0
    </select>
</mapper>
